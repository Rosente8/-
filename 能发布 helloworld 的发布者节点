发布者的节点
#include <ros/ros.h>
#include <std_msgs/String.h>                                                              // 使用字符串消息类型

int main(int argc, char **argv) {
    ros::init(argc, argv, "talker");                                                      //初始化ROS节点   名称为talker
    ros::NodeHandle nh;                                                                   //创建节点句柄    访问ROS服务和参数
    ros::Publisher chatter_pub = nh.advertise<std_msgs::String>("chatter", 1000);         //创建发布者      话题：chatter，消息类型：std_msgs/String，队列长度：1000
    ros::Rate loop_rate(1);                                                               //设置发布频率    1Hz，每秒1次
    int count = 0;
    while (ros::ok()) {
        std_msgs::String msg;
        msg.data = "Hello World " + std::to_string(count);                                //创建消息对象
        chatter_pub.publish(msg);                                                         //发布消息
        ROS_INFO("Published: %s", msg.data.c_str());                                      //还可以打印日志    
        loop_rate.sleep();                                                                //按频率休眠  
        ++count;
    }
    return 0;
}
订阅者节点实现
#include <ros/ros.h>
#include <std_msgs/String.h>                                                               //应该与发布者消息类型一致

void messageCallback(const std_msgs::String::ConstPtr& msg) {                              //定义回调函数来处理接收到的消息
    ROS_INFO("Received: %s", msg->data.c_str());
}

int main(int argc, char **argv) {
    ros::init(argc, argv, "listener");                                                      //初始化ROS节点（名称：listener）
    ros::NodeHandle nh;                                                                     //创建节点句柄
    ros::Subscriber sub = nh.subscribe("chatter", 1000, messageCallback);                   //创建订阅者（话题：chatter，回调函数：messageCallback）
    ros::spin();                                                                            //进入循环，处理回调（阻塞式）
    return 0;
}

验证示例
mkdir -p ~/catkin_ws/src
cd ~/catkin_ws
catkin_make                                                                                  //创建工作空间
cd src
catkin_create_pkg hello_communication rospy std_msgs                                         //创建ROS包

在~/catkin_ws/src/hello_communication/CMakeLists.txt中添加编译规则

add_executable(talker src/talker.cpp)
target_link_libraries(talker ${catkin_LIBRARIES})
add_executable(listener src/listener.cpp)
target_link_libraries(listener ${catkin_LIBRARIES})

cd ~/catkin_ws                                                                                //编译空间
catkin_make

运行节点
source devel/setup.bash
rosrun hello_communication talker                                                             //新终端1运行发布者
source devel/setup.bash
rosrun hello_communication listener                                                           //新终端2运行订阅者


结果
发布者终端：每秒打印Published: Hello World X（X为计数）。
订阅者终端：每秒打印Received: Hello World X。
可通过rostopic echo /chatter查看话题中的消息（新终端执行）。






